# ──────────────────────────────────────────────
# IBM watsonx.ai Credentials
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# IBM Cloud API Key (from IBM Cloud IAM)
IBM_CLOUD_API_KEY=Uin1Fg3YX9oigLg368SKNxSGswYvjekWBv7Fiipyt5r0

# watsonx.ai Project ID
WATSONX_PROJECT_ID=f26575a5-9780-4a92-85aa-484acd81f089

# watsonx.ai Service URL (region-specific)
# Options: https://us-south.ml.cloud.ibm.com
#          https://eu-de.ml.cloud.ibm.com
#          https://au-syd.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ──────────────────────────────────────────────
# Flask Application Settings
# ──────────────────────────────────────────────
FLASK_SECRET_KEY=change_this_to_a_long_random_secret_key
FLASK_ENV=development
FLASK_DEBUG=0
DATABASE_URL=sqlite:///academic_integrity.db
MAX_CONTENT_LENGTH=16777216

# ──────────────────────────────────────────────
# AGENT_INSTRUCTIONS — Institutional Customisation
# Adjust these to match your institution's policies
# ──────────────────────────────────────────────

# Similarity threshold above which a passage is flagged (0.0–1.0)
SIMILARITY_THRESHOLD=0.75

# Minimum citation density (citations per 1000 words) expected
MIN_CITATION_DENSITY=2.5

# Style consistency deviation tolerance (0.0–1.0; lower = stricter)
STYLE_DEVIATION_TOLERANCE=0.30

# Report format: "detailed" | "summary" | "instructor_only"
REPORT_FORMAT=detailed

# Privacy mode: "full" | "anonymised" | "hash_only"
PRIVACY_MODE=full

# Watsonx Granite model to use for analysis
GRANITE_MODEL_ID=ibm/granite-13b-instruct-v2

# Maximum tokens per watsonx API call
WATSONX_MAX_TOKENS=1500

# Academic integrity policy text shown to students on upload
INTEGRITY_POLICY_TEXT=By submitting this assignment you confirm the work is your own and complies with the institution academic integrity policy.

# Flagging confidence level: "low" | "medium" | "high"
# low = flag more, high = flag only strong signals
FLAGGING_CONFIDENCE=medium

# Enable instructor feedback integration
ENABLE_INSTRUCTOR_FEEDBACK=true

# Enable writing-style consistency across multiple submissions
ENABLE_STYLE_ANALYSIS=true
